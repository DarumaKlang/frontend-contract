{
  "name": "contract-generator",
  "version": "0.1.0",
  "homepage": "https://contract-generator.com",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "migrate:templates": "ts-node scripts/migrateTemplates.ts",
    "migrate:templates:prod": "node -e \"const prompt = require('prompt-sync')(); const answer = prompt('Are you sure you want to migrate templates to production? (yes/no): '); if (answer.toLowerCase() === 'yes') { require('child_process').execSync('ts-node scripts/migrateTemplates.ts', { stdio: 'inherit' }); } else { console.log('Migration cancelled.'); }\"",
    "validate:template-coverage": "ts-node scripts/validateTemplateCoverage.ts"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@stripe/stripe-js": "^9.8.0",
    "@supabase/supabase-js": "^2.110.0",
    "@tailwindcss/cli": "^4.3.2",
    "@vercel/analytics": "^2.0.1",
    "dotenv": "^16.6.1",
    "handlebars": "^4.7.9",
    "isomorphic-dompurify": "^3.18.0",
    "jose": "^5.2.3",
    "lucide-react": "^0.542.0",
    "next": "16.2.9",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "stripe": "^14.25.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "fast-check": "^3.23.2",
    "prompt-sync": "^4.2.0",
    "tailwindcss": "^4.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vercel": "^54.20.1",
    "vitest": "^1.6.1"
  }
}
